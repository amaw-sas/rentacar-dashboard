NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Localiza proxy (Railway). Leave empty to disable Localiza API calls.
LOCALIZA_PROXY_URL=
PROXY_API_KEY=

# Timeout (ms) for the dashboard->proxy reservation call. On expiry the route
# returns 504 {error:"upstream_timeout"} instead of hanging into Vercel's hard
# kill. MUST stay below the function maxDuration (30s) and above the proxy's
# LOCALIZA_TIMEOUT_MS (25s). Default 28000.
# Invariant: LOCALIZA_TIMEOUT_MS (proxy) < PROXY_TIMEOUT_MS < maxDuration(30000).
PROXY_TIMEOUT_MS=28000

# MCP server (issue #172) — anonymous /api/mcp endpoint, no x-api-key/OAuth.
# Anti-abuse = this HMAC secret signs/expires reservation quotes (+ Vercel Firewall).
# Use a strong random value >= 32 chars, e.g. `openssl rand -hex 32`.
MCP_QUOTE_SECRET=
