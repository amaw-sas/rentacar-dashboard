# Staging environment — redirects notifications to test services
# Copy to .env.local for local testing without sending real emails/WhatsApp

# Supabase (same as production or use a separate project)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email — use Mailtrap sandbox (https://mailtrap.io) instead of Gmail
# All 3 franchises point to the same Mailtrap inbox
ALQUILATUCARRO_MAIL_HOST=sandbox.smtp.mailtrap.io
ALQUILATUCARRO_MAIL_PORT=587
ALQUILATUCARRO_MAIL_USER=your-mailtrap-user
ALQUILATUCARRO_MAIL_PASS=your-mailtrap-pass

ALQUILAME_MAIL_HOST=sandbox.smtp.mailtrap.io
ALQUILAME_MAIL_PORT=587
ALQUILAME_MAIL_USER=your-mailtrap-user
ALQUILAME_MAIL_PASS=your-mailtrap-pass

ALQUICARROS_MAIL_HOST=sandbox.smtp.mailtrap.io
ALQUICARROS_MAIL_PORT=587
ALQUICARROS_MAIL_USER=your-mailtrap-user
ALQUICARROS_MAIL_PASS=your-mailtrap-pass

LOCALIZA_NOTIFICATION_EMAIL=localiza-test@mailtrap.io
LOCALIZA_NOTIFICATION_BCC_EMAIL=bcc-test@mailtrap.io

# WhatsApp — leave empty to disable Wati in staging
WATI_API_URL=
WATI_API_TOKEN=

# GHL — leave empty to disable GHL in staging
ALQUILAME_GHL_API_KEY=

# Proxy — leave empty to disable Localiza API calls
LOCALIZA_PROXY_URL=
PROXY_API_KEY=

# Cron
CRON_SECRET=test-cron-secret
