# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example
!.env.staging.example
!scripts/migration/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI Framework
/.claude/*
!/.claude/rules/
/.claude/rules/.manifest-checksums
/CLAUDE.md
/hooks/*.db
/hooks/__pycache__/
/.ralph/
/.research/
/.brainstorm/
/.visual-companion/
/docs/specs/
.env*.local

# git worktrees colocated with the repo
/.worktrees/

# AI Framework template rules (one-time sync)
/.ralph/*
!/.ralph/specs/
!/.ralph/specs/**
!/docs/specs/
!/docs/specs/**
/.claude/metrics.jsonl
/.claude/metrics.jsonl.*

# migration pre-flight (issue #16): auto reports are secret, hand-written verification doc is committed
/docs/migration-runs/preflight-*.json
/docs/migration-runs/*.json
!/docs/migration-runs/preflight-verification-2026-05-12.md

# migration pre-flight: operator-managed Python venv + bytecode (never committed)
/scripts/migration/.venv/
/scripts/migration/__pycache__/
/scripts/migration/*.pyc
