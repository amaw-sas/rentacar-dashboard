# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example
!.env.staging.example
!scripts/migration/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI Framework
/.claude/*
!/.claude/rules/
/.claude/rules/.manifest-checksums
/CLAUDE.md
/hooks/*.db
/hooks/__pycache__/
/.ralph/
/.research/
/.brainstorm/
/.visual-companion/
/docs/specs/
.env*.local

# git worktrees colocated with the repo
/.worktrees/

# AI Framework template rules (one-time sync)
/.ralph/*
!/.ralph/specs/
!/.ralph/specs/**
!/docs/specs/
!/docs/specs/**
/.claude/metrics.jsonl
/.claude/metrics.jsonl.*

# migration pre-flight (issue #16): auto reports are secret, hand-written verification doc is committed
/docs/migration-runs/preflight-*.json
/docs/migration-runs/*.json
!/docs/migration-runs/preflight-verification-2026-05-12.md

# migration pre-flight: operator-managed Python venv + bytecode (never committed)
/scripts/migration/.venv/
/scripts/migration/__pycache__/
/scripts/migration/*.pyc

# customers ETL (issue #19): per-row reports carry identification numbers (PII)
/docs/migration-runs/*.jsonl

# log_veh raw extraction (issue #45 Phase 2): the whole run dir is PII-bearing
# (response_raw + source_ip) and local-only — chunks, .partial, manifest, and the
# 0600 temp creds file. PII-free numbers live in the committed run-summary instead.
# This is NOT inherited from the *.json rule above (that only reaches files directly
# in docs/migration-runs/, not this nested subdir) — the rule must be explicit.
/docs/migration-runs/log-veh-extract-*/

# data-ops PII (issue #62): never commit raw data dumps — they carry customer PII (cédula, phone, email).
# Audit artifacts (*.sql rollback scripts, *.md run summaries) stay tracked; only data dumps are ignored.
# Covers common dump formats under docs/data-ops/ (json/ndjson/csv/tsv/xlsx/gz/zip); **/*.jsonl is repo-wide.
docs/data-ops/**/*.json
docs/data-ops/**/*.ndjson
docs/data-ops/**/*.csv
docs/data-ops/**/*.tsv
docs/data-ops/**/*.xlsx
docs/data-ops/**/*.gz
docs/data-ops/**/*.zip
**/*.jsonl
