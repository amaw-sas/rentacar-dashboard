{
  "openapi": "3.0.3",
  "info": {
    "title": "Rentacar API",
    "version": "1.0.0",
    "description": "API de reservas del admin de rentacar. Reemplaza el backend Laravel.\n\nEl `servers[0].url` apunta automáticamente al dominio que sirve este documento (cada dominio de marca se auto-describe), con fallback al dominio canónico https://rentacar-dashboard-delta.vercel.app.\n\n## Valores en runtime\n- `apiKey`: valor de RESERVATION_API_KEY (header `x-api-key`, solo para crear reservas)\n- `referenceToken`: se llena automáticamente tras llamar availability\n- `rateQualifier`: se llena automáticamente tras llamar availability"
  },
  "servers": [
    {
      "url": "https://rentacar-dashboard-delta.vercel.app",
      "description": "Rentacar public + admin API"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "AvailabilityRequest": {
        "type": "object",
        "required": ["pickupLocation", "returnLocation", "pickupDateTime", "returnDateTime"],
        "properties": {
          "pickupLocation": { "type": "string", "example": "AABOT", "description": "Código de sucursal de recogida" },
          "returnLocation": { "type": "string", "example": "AABOT", "description": "Código de sucursal de devolución" },
          "pickupDateTime": { "type": "string", "example": "2026-05-01T09:00:00" },
          "returnDateTime": { "type": "string", "example": "2026-05-05T09:00:00" }
        }
      },
      "AvailabilityResponseItem": {
        "type": "object",
        "properties": {
          "categoryCode": { "type": "string", "example": "C" },
          "categoryDescription": { "type": "string", "example": "Gama C Económico Mecánico", "description": "Nombre de la gama (categoría) en español, traducido en origen desde el catálogo curado de Localiza. Cae al texto crudo de Localiza si la gama aún no está curada." },
          "totalAmount": { "type": "number", "example": 400000 },
          "estimatedTotalAmount": { "type": "number", "example": 476000 },
          "vehicleDayCharge": { "type": "number", "example": 100000, "description": "Tarifa diaria del vehículo (solo display)." },
          "numberDays": { "type": "number", "example": 4, "description": "Días que cotiza Localiza. NO se usa como selected_days; este se calcula del rango de fechas." },
          "coverageUnitCharge": { "type": "number", "example": 10000, "description": "Cargo unitario de cobertura básica (solo display)." },
          "coverageQuantity": { "type": "number", "example": 4, "description": "Días de cobertura básica. Se mapea a coverage_days en la reserva." },
          "coverageTotalAmount": { "type": "number", "example": 40000, "description": "Total de cobertura básica. Se mapea a coverage_price." },
          "extraHoursQuantity": { "type": "number", "example": 0, "description": "Horas extra cotizadas. Se mapea a extra_hours." },
          "extraHoursUnityAmount": { "type": "number", "example": 0, "description": "Cargo unitario de hora extra (solo display)." },
          "extraHoursTotalAmount": { "type": "number", "example": 0, "description": "Total de horas extra. Se mapea a extra_hours_price." },
          "taxFeeAmount": { "type": "number", "example": 40000, "description": "Tarifa administrativa. Se mapea a tax_fee." },
          "taxFeePercentage": { "type": "number", "example": 10, "description": "Porcentaje de la tarifa administrativa (solo display)." },
          "IVAFeeAmount": { "type": "number", "example": 36000, "description": "IVA. Se mapea a iva_fee." },
          "returnFeeAmount": { "type": "number", "example": 0, "description": "Cargo por devolución en sede distinta. Se mapea a return_fee." },
          "discountAmount": { "type": "number", "example": 0, "description": "Monto de descuento aplicado (solo display)." },
          "discountPercentage": { "type": "number", "example": 0, "description": "Porcentaje de descuento aplicado (solo display)." },
          "passengerCount": { "type": "integer", "example": 5, "description": "Capacidad de pasajeros de la gama (catálogo curado). Ausente si la gama aún no está curada." },
          "luggageCount": { "type": "integer", "example": 4, "description": "Capacidad de maletas de la gama. Ausente si la gama aún no está curada." },
          "transmission": { "type": "string", "enum": ["automatic", "manual"], "example": "automatic", "description": "Tipo de transmisión. Ausente si la gama aún no está curada." },
          "hasAc": { "type": "boolean", "example": true, "description": "Si la gama tiene aire acondicionado. Ausente si la gama aún no está curada." },
          "picoyplacaExempt": { "type": "boolean", "example": false, "description": "true = exenta de pico y placa. Ausente si la gama aún no está curada." },
          "referenceToken": {
            "type": "string",
            "description": "Token requerido para crear reserva — se extrae automáticamente al body"
          },
          "rateQualifier": {
            "type": "string",
            "description": "Rate qualifier requerido para crear reserva"
          }
        }
      },
      "ReservationRequest": {
        "type": "object",
        "required": [
          "fullname", "identification_type", "identification", "phone", "email",
          "category", "pickup_location", "return_location",
          "pickup_date", "pickup_hour", "return_date", "return_hour",
          "selected_days", "total_price", "total_price_to_pay", "franchise"
        ],
        "properties": {
          "fullname": { "type": "string", "example": "Test Usuario API" },
          "identification_type": { "type": "string", "enum": ["CC", "CE", "NIT", "PP", "TI"], "example": "CC" },
          "identification": { "type": "string", "example": "9999999999" },
          "phone": { "type": "string", "example": "+573001234567" },
          "email": { "type": "string", "example": "test-api@example.com" },
          "category": { "type": "string", "example": "C", "description": "Código de categoría" },
          "pickup_location": { "type": "string", "example": "AABOT", "description": "Código de sucursal" },
          "return_location": { "type": "string", "example": "AABOT" },
          "pickup_date": { "type": "string", "format": "date", "example": "2026-05-01" },
          "pickup_hour": { "type": "string", "example": "09:00" },
          "return_date": { "type": "string", "format": "date", "example": "2026-05-05" },
          "return_hour": { "type": "string", "example": "09:00" },
          "selected_days": { "type": "integer", "example": 4, "description": "< 30 para standard, >= 30 para mensualidad" },
          "extra_hours": { "type": "integer", "default": 0 },
          "extra_hours_price": { "type": "number", "default": 0 },
          "coverage_days": { "type": "integer", "default": 0 },
          "coverage_price": { "type": "number", "default": 0 },
          "return_fee": { "type": "number", "default": 0 },
          "tax_fee": { "type": "number", "example": 40000 },
          "iva_fee": { "type": "number", "example": 36000 },
          "total_price": { "type": "number", "example": 400000 },
          "total_price_to_pay": { "type": "number", "example": 476000 },
          "franchise": { "type": "string", "enum": ["alquilatucarro", "alquilame", "alquicarros"], "example": "alquilame" },
          "user": { "type": "string", "nullable": true, "description": "Código del referido (opcional)" },
          "monthly_mileage": { "type": "string", "nullable": true, "enum": [null, "1000", "2000", "3000"] },
          "total_insurance": { "type": "boolean", "default": false },
          "reference_token": { "type": "string", "description": "Obtenido de /api/reservations/availability (requerido si selected_days < 30)" },
          "rate_qualifier": { "type": "string", "description": "Obtenido de /api/reservations/availability (requerido si selected_days < 30)" },
          "extra_driver": { "type": "boolean", "default": false },
          "baby_seat": { "type": "boolean", "default": false },
          "wash": { "type": "boolean", "default": false },
          "flight": { "type": "boolean", "default": false },
          "aeroline": { "type": "string", "nullable": true },
          "flight_number": { "type": "string", "nullable": true }
        }
      },
      "ReservationResponse": {
        "type": "object",
        "properties": {
          "reserveCode": { "type": "string", "example": "AV78XC3JDA" },
          "reservationStatus": { "type": "string", "example": "reservado" }
        }
      },
      "LocationDirectoryItem": {
        "type": "object",
        "properties": {
          "slug": { "type": "string", "example": "armenia-aeropuerto", "description": "Identificador URL-safe de la sede" },
          "code": { "type": "string", "example": "AARME", "description": "Código de sucursal Localiza — el valor que aceptan availability y reservations" },
          "city": { "type": "string", "example": "armenia", "description": "Ciudad en minúscula" },
          "name": { "type": "string", "example": "Armenia Aeropuerto" },
          "status": { "type": "string", "example": "active", "description": "Siempre 'active' — el directorio solo lista sedes activas" },
          "pickup_address": { "type": "string", "example": "Aeropuerto el Edén – Local # 18" },
          "pickup_map": { "type": "string", "example": "https://maps.app.goo.gl/yxKpFsswp4DKd6BL7" },
          "schedule": {
            "type": "object",
            "description": "Horario en texto para mostrar",
            "properties": {
              "display": { "type": "string", "example": "Lun-Vie 06:00-19:00 | Sáb, Dom y fest 08:00-16:00" }
            }
          }
        }
      },
      "LocationDirectoryResponse": {
        "type": "object",
        "properties": {
          "count": { "type": "integer", "example": 31 },
          "locations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LocationDirectoryItem" }
          }
        }
      },
      "RentalRequirements": {
        "type": "object",
        "description": "Requisitos generales de alquiler. Contenido autorizado por el negocio (espejo del email de confirmación). Sin precios (son dinámicos y van en la cotización).",
        "properties": {
          "documentosRequeridos": {
            "type": "array",
            "description": "Documentos a presentar en la recogida.",
            "items": {
              "type": "object",
              "properties": {
                "titulo": { "type": "string", "example": "Tarjeta de crédito" },
                "detalle": { "type": "string", "example": "Solo se reciben pagos con tarjetas de crédito físicas." }
              }
            }
          },
          "reglaLicenciaConduccion": { "type": "string", "description": "Regla clave para extranjeros: la licencia determina el documento de identidad a presentar." },
          "formaDePago": { "type": "string" },
          "conductorAdicional": { "type": "string" },
          "politicasDeUso": { "type": "array", "items": { "type": "string" } },
          "recogida": { "type": "string" },
          "fuente": { "type": "string" }
        }
      }
    }
  },
  "security": [{ "ApiKeyAuth": [] }],
  "paths": {
    "/api/mcp/{transport}": {
      "post": {
        "operationId": "mcpTransport",
        "summary": "Servidor MCP de reservas (Streamable HTTP)",
        "description": "Endpoint del servidor MCP (Model Context Protocol) para clientes de IA. **No es REST**: habla JSON-RPC sobre Streamable HTTP vía `mcp-handler`. Expone dos herramientas — `buscar_disponibilidad` y `crear_solicitud_reserva` — que envuelven el mismo flujo Localiza de `/api/reservations(/availability)`. El estado de cotización viaja como un `quote` entre ambas (servidor stateless). **Anónimo, sin autenticación** (sin OAuth, sin `x-api-key`): el control de integridad es el `quote` firmado con HMAC-SHA256 (`MCP_QUOTE_SECRET`) y con expiración de 30 min, más rate-limit de Vercel Firewall y revisión del operador (estado `nueva`). Decisión en `docs/specs/issue-172/decision-drop-oauth.md`.",
        "tags": ["MCP"],
        "parameters": [
          {
            "name": "transport",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "mcp" },
            "description": "Segmento de transporte que resuelve mcp-handler (Streamable HTTP)."
          }
        ],
        "responses": {
          "200": { "description": "Respuesta JSON-RPC / stream MCP" }
        }
      }
    },
    "/api/locations": {
      "get": {
        "operationId": "getLocations",
        "summary": "Directorio público de sedes",
        "description": "Catálogo canónico `slug ↔ code ↔ ciudad` de las sedes activas, con dirección, mapa y horario. **Público, sin autenticación** (`x-api-key` no requerida). El `code` devuelto es exactamente el que aceptan `/api/reservations/availability` y `/api/reservations`.",
        "tags": ["Sedes"],
        "security": [],
        "responses": {
          "200": {
            "description": "Directorio de sedes activas",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LocationDirectoryResponse" }
              }
            }
          },
          "500": { "description": "Error al cargar el directorio" }
        }
      }
    },
    "/api/requirements": {
      "get": {
        "operationId": "getRequirements",
        "summary": "Requisitos de alquiler",
        "description": "Requisitos generales para alquilar (documentos, forma de pago, regla de licencia para extranjeros, políticas de uso). **Público, sin autenticación** (`x-api-key` no requerida). Contenido estático autorizado por el negocio.",
        "tags": ["Requisitos"],
        "security": [],
        "responses": {
          "200": {
            "description": "Requisitos de alquiler",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RentalRequirements" }
              }
            }
          }
        }
      }
    },
    "/api/reservations/availability": {
      "post": {
        "operationId": "checkAvailability",
        "summary": "Consultar disponibilidad de vehículos",
        "description": "Pass-through al proxy Localiza. Retorna las categorías disponibles con `referenceToken` y `rateQualifier` para cada una.\n\n**Tip Apidog**: en la respuesta, guarda `referenceToken` y `rateQualifier` como variables de entorno para usarlas en el POST /api/reservations.",
        "tags": ["Reservas"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AvailabilityRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lista de vehículos disponibles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AvailabilityResponseItem" }
                }
              }
            }
          },
          "400": { "description": "Cuerpo inválido o campos requeridos faltantes" },
          "502": { "description": "Error al comunicar con proxy/Localiza" }
        }
      }
    },
    "/api/reservations": {
      "post": {
        "operationId": "createReservation",
        "summary": "Crear reserva",
        "description": "Crea una reserva. Para standard (selected_days < 30) llama al proxy → Localiza API. Para mensualidad (>= 30) guarda directamente. Dispara notificaciones (email + WhatsApp + GHL).",
        "tags": ["Reservas"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReservationRequest" },
              "examples": {
                "standard": {
                  "summary": "Reserva standard (llama Localiza)",
                  "value": {
                    "fullname": "Test Usuario API",
                    "identification_type": "CC",
                    "identification": "9999999999",
                    "phone": "+573001234567",
                    "email": "test-api@example.com",
                    "category": "C",
                    "pickup_location": "AABOT",
                    "return_location": "AABOT",
                    "pickup_date": "2026-05-01",
                    "pickup_hour": "09:00",
                    "return_date": "2026-05-05",
                    "return_hour": "09:00",
                    "selected_days": 4,
                    "tax_fee": 40000,
                    "iva_fee": 36000,
                    "total_price": 400000,
                    "total_price_to_pay": 476000,
                    "franchise": "alquilame",
                    "reference_token": "{{referenceToken}}",
                    "rate_qualifier": "{{rateQualifier}}"
                  }
                },
                "mensualidad": {
                  "summary": "Reserva mensualidad (no llama Localiza)",
                  "value": {
                    "fullname": "Test Mensual",
                    "identification_type": "CC",
                    "identification": "8888888888",
                    "phone": "+573009876543",
                    "email": "test-mensual@example.com",
                    "category": "C",
                    "pickup_location": "AABOT",
                    "return_location": "AABOT",
                    "pickup_date": "2026-05-01",
                    "pickup_hour": "09:00",
                    "return_date": "2026-05-31",
                    "return_hour": "09:00",
                    "selected_days": 30,
                    "tax_fee": 0,
                    "iva_fee": 0,
                    "total_price": 3865990,
                    "total_price_to_pay": 3865990,
                    "franchise": "alquilame",
                    "monthly_mileage": "1000"
                  }
                },
                "standard_con_extras": {
                  "summary": "Standard con extras (seguro, silla, lavado)",
                  "value": {
                    "fullname": "Test Con Extras",
                    "identification_type": "CC",
                    "identification": "7777777777",
                    "phone": "+573005555555",
                    "email": "test-extras@example.com",
                    "category": "C",
                    "pickup_location": "AABOT",
                    "return_location": "AABOT",
                    "pickup_date": "2026-05-01",
                    "pickup_hour": "09:00",
                    "return_date": "2026-05-05",
                    "return_hour": "09:00",
                    "selected_days": 4,
                    "tax_fee": 40000,
                    "iva_fee": 36000,
                    "total_price": 580000,
                    "total_price_to_pay": 656000,
                    "franchise": "alquilame",
                    "total_insurance": true,
                    "extra_driver": true,
                    "baby_seat": true,
                    "wash": true,
                    "reference_token": "{{referenceToken}}",
                    "rate_qualifier": "{{rateQualifier}}"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reserva creada exitosamente",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReservationResponse" }
              }
            }
          },
          "400": { "description": "Datos inválidos o faltantes" },
          "401": { "description": "API key inválida" },
          "502": { "description": "Error al comunicar con proxy/Localiza" }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Reservas",
      "description": "Endpoints de reservas del admin — reemplazan al Laravel"
    },
    {
      "name": "Sedes",
      "description": "Directorio público de sedes — fuente única slug↔code↔ciudad para web y agentes"
    }
  ]
}
