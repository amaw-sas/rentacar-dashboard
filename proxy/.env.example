# Localiza proxy (Railway, separate deployable). Copy to .env for local dev.

# Shared secret the dashboard sends as x-api-key (must match the dashboard's
# PROXY_API_KEY).
PROXY_API_KEY=your-proxy-api-key

# Localiza SOAP credentials
LOCALIZA_ENDPOINT=https://localiza-soap-endpoint
LOCALIZA_USERNAME=your-localiza-username
LOCALIZA_PASSWORD=your-localiza-password
LOCALIZA_TOKEN=your-localiza-token
LOCALIZA_REQUESTOR_ID=your-localiza-requestor-id

# Port the Express server listens on (default 3001)
PORT=3001

# --- Hardening tunables (issue #99) — all optional, safe defaults below ---

# Timeout (ms) for each Localiza SOAP call. On expiry the proxy returns 504
# {error:"upstream_timeout"} instead of hanging. MUST stay below the dashboard's
# PROXY_TIMEOUT_MS (28000) so this layer fails first. Default 25000.
# Invariant: LOCALIZA_TIMEOUT_MS < PROXY_TIMEOUT_MS < maxDuration (30000).
LOCALIZA_TIMEOUT_MS=25000

# Dedupe window (ms) for the reservation endpoint: a repeat booking with the same
# fingerprint within this window returns the original result instead of creating a
# second Localiza reservation (anti reload+resubmit). Default 60000.
DEDUPE_TTL_MS=60000

# Hard cap on cached reservation successes (memory bound on the long-lived proxy).
# Default 5000.
DEDUPE_MAX_ENTRIES=5000
