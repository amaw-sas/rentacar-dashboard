# Migration pre-flight check — required environment variables.
# Copy to `.env` (gitignored) and fill in. All 5 are mandatory; a missing
# or empty value makes the script exit 4 before any DB connection.

# Legacy MariaDB (rentacar_audit dump from audit commit c70503e), read-only.
LEGACY_DB_HOST=
LEGACY_DB_USER=
LEGACY_DB_PASSWORD=
LEGACY_DB_NAME=

# Destination Postgres connection string (Supabase: Project Settings ->
# Database -> Connection string -> URI). Format:
# postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Read-only by convention — the script issues SELECT-only queries.
SUPABASE_DB_URL=
